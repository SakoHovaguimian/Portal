{
  "name": "semantic-web-template",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @semantic-web/web dev",
    "dev:auth": "pnpm --filter @semantic-web/web auth:emulator",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "pnpm --filter @semantic-web/web test:unit && pnpm --filter @semantic-web/core test",
    "test:e2e": "pnpm --filter @semantic-web/web test:e2e",
    "api:generate": "pnpm --filter @semantic-web/api-sdk api:generate",
    "api:check": "pnpm --filter @semantic-web/api-sdk api:check",
    "clean": "turbo clean && find . -name node_modules -type d -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "openapi-typescript": "^7.6.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
