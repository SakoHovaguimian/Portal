{
  "name": "@semantic-web/api-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "api:generate": "openapi-typescript openapi/mock-openapi.json -o generated/schema.d.ts",
    "api:check": "node scripts/check-generated.mjs"
  },
  "dependencies": {
    "@semantic-web/core": "workspace:*"
  },
  "devDependencies": {
    "@semantic-web/config": "workspace:*",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2"
  }
}
